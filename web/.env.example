# ── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server only — usado pelo webhook Stripe para criar payments
# sem RLS): https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (pagamento por cartão) ────────────────────────────────────
# Configurar em https://dashboard.stripe.com/apikeys
# Sem estas vars o botão "Pagar com cartão" mostra-se desativado.
STRIPE_SECRET_KEY=
# Configurar em https://dashboard.stripe.com/webhooks (endpoint:
# /api/webhooks/stripe, evento checkout.session.completed)
STRIPE_WEBHOOK_SECRET=

# ── Vinti4 / SISP (pagamento local Cabo Verde) ───────────────────────
# Dados do contrato de comerciante com a SISP. Sem estas 3 vars o método
# "Vinti4" aparece como "em breve" e nada quebra.
VINTI4_POS_ID=
VINTI4_POS_AUTH_CODE=
VINTI4_GATEWAY_URL=

# ── Emails transacionais (Resend) ────────────────────────────────────
# Cria conta grátis em https://resend.com → API Keys. Sem esta var nenhum
# email é enviado (tudo continua a funcionar, só não há emails).
RESEND_API_KEY=
# Remetente. Tem de usar um domínio verificado no Resend (ex: imoauto.cv).
# Antes de verificar o domínio, podes testar com "IMOAUTO <onboarding@resend.dev>".
EMAIL_FROM=
# Segredo partilhado entre o Database Webhook do Supabase e /api/webhooks/
# notification-email (inventa um valor aleatório e mete o mesmo nos dois lados).
NOTIFICATION_WEBHOOK_SECRET=

# ── Pagamento simulado (pré-Vinti4) ──────────────────────────────────
# true = ativa o fluxo de pagamento SIMULADO (página /pay/simulate, botão
# Vinti4 em modo teste). Desligar quando o Vinti4 real estiver ativo.
PAYMENT_SIMULATION=

# ── Vercel Cron ──────────────────────────────────────────────────────
# Vercel gera automaticamente; mete o valor em Settings > Env Variables
CRON_SECRET=
