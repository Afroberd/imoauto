# ── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server only — usado pelo webhook Stripe para criar payments
# sem RLS): https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (pagamento por cartão) ────────────────────────────────────
# Configurar em https://dashboard.stripe.com/apikeys
# Sem estas vars o botão "Pagar com cartão" mostra-se desativado.
STRIPE_SECRET_KEY=
# Configurar em https://dashboard.stripe.com/webhooks (endpoint:
# /api/webhooks/stripe, evento checkout.session.completed)
STRIPE_WEBHOOK_SECRET=

# ── Vinti4 / SISP (pagamento local Cabo Verde) ───────────────────────
# Dados do contrato de comerciante com a SISP. Sem estas 3 vars o método
# "Vinti4" aparece como "em breve" e nada quebra.
VINTI4_POS_ID=
VINTI4_POS_AUTH_CODE=
VINTI4_GATEWAY_URL=

# ── Vercel Cron ──────────────────────────────────────────────────────
# Vercel gera automaticamente; mete o valor em Settings > Env Variables
CRON_SECRET=
